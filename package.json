{
  "name": "semantic-ui-react-icon-picker",
  "version": "1.0.0",
  "description": "Icon picker component for use with semantic-ui-react",
  "author": "samuel-knutson",
  "license": "MIT",
  "repository": "samuel-knutson/semantic-ui-react-icon-picker",
  "main": "dist/index.js",
  "module": "dist/index.modern.js",
  "source": "src/index.ts",
  "engines": {
    "node": ">=10"
  },
  "scripts": {
    "build": "microbundle-crl --no-compress --format modern,cjs --tsconfig tsconfig.json",
    "start": "microbundle-crl watch --no-compress --format modern,cjs --tsconfig tsconfig.json",
    "prepare": "run-s build",
    "test": "run-s test:unit test:lint test:build",
    "test:build": "run-s build",
    "test:lint": "eslint .",
    "test:unit": "cross-env CI=1 react-scripts test --env=jsdom",
    "test:watch": "react-scripts test --env=jsdom",
    "predeploy": "cd example && npm install && npm run build",
    "deploy": "gh-pages -d example/build",
    "typecheck": "node -e \"const fs=require('fs');const hasTs=fs.existsSync('tsconfig.json')||fs.readdirSync('src').some(f=>f.endsWith('.ts')||f.endsWith('.tsx'));if(hasTs){require('child_process').execSync('npx tsc --noEmit',{stdio:'inherit'});}else{console.log('No TypeScript sources found; skipping strict typecheck.');}\"",
    "test:ci": "run-s test:lint typecheck test:unit test:build",
    "test:coverage": "cross-env CI=1 react-scripts test --env=jsdom --watchAll=false --coverage"
  },
  "peerDependencies": {
    "react": "^16.0.0",
    "semantic-ui-react": "^0.88.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.10.1",
    "@testing-library/react": "^10.3.0",
    "@testing-library/user-event": "^12.0.11",
    "babel-eslint": "^10.0.3",
    "cross-env": "^7.0.2",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^6.7.0",
    "eslint-config-standard": "^14.1.0",
    "eslint-config-standard-react": "^9.2.0",
    "eslint-plugin-import": "^2.18.2",
    "eslint-plugin-node": "^11.0.0",
    "eslint-plugin-prettier": "^3.1.1",
    "eslint-plugin-promise": "^4.2.1",
    "eslint-plugin-react": "^7.17.0",
    "eslint-plugin-standard": "^4.0.1",
    "gh-pages": "^2.2.0",
    "microbundle-crl": "^0.13.10",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.0.4",
    "react": "^16.13.1",
    "react-dom": "^16.13.1",
    "react-scripts": "^5.0.1",
    "semantic-ui-react": "^0.88.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.8.3"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "react-infinite-scroll-component": "^5.0.5"
  },
  "types": "dist/index.d.ts",
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/setupTests.js",
      "!src/icons.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 90,
        "lines": 90,
        "statements": 90
      }
    }
  }
}
