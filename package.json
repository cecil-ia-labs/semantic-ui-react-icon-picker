{
  "name": "semantic-ui-react-icon-picker",
  "version": "1.0.0",
  "description": "Icon picker component for use with semantic-ui-react",
  "author": "samuel-knutson",
  "license": "MIT",
  "repository": "samuel-knutson/semantic-ui-react-icon-picker",
  "main": "dist/index.js",
  "module": "dist/index.modern.js",
  "source": "src/index.ts",
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "build": "microbundle-crl --no-compress --format modern,cjs --tsconfig tsconfig.json",
    "start": "microbundle-crl watch --no-compress --format modern,cjs --tsconfig tsconfig.json",
    "prepare": "run-s build",
    "test": "run-s test:unit test:lint test:build",
    "test:build": "run-s build",
    "test:lint": "eslint .",
    "test:unit": "cross-env CI=1 react-scripts test --env=jsdom",
    "test:watch": "react-scripts test --env=jsdom",
    "predeploy": "cd example && npm install && npm run build",
    "deploy": "gh-pages -d example/build",
    "typecheck": "node -e \"const fs=require('fs');const hasTs=fs.existsSync('tsconfig.json')||fs.readdirSync('src').some(f=>f.endsWith('.ts')||f.endsWith('.tsx'));if(hasTs){require('child_process').execSync('npx tsc --noEmit',{stdio:'inherit'});}else{console.log('No TypeScript sources found; skipping strict typecheck.');}\"",
    "test:ci": "run-s test:lint typecheck test:unit test:build",
    "test:coverage": "cross-env CI=1 react-scripts test --env=jsdom --watchAll=false --coverage"
  },
  "resolutions": {
    "typescript": "^6.0.3",
    "eslint": "^10.3.0"
  },
  "overrides": {
    "typescript": "^6.0.3",
    "eslint": "^10.3.0"
  },
  "peerDependencies": {
    "react": ">=16.14.0",
    "semantic-ui-react": ">=2.1.5"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.6",
    "@babel/preset-react": "^7.28.5",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^12.1.5",
    "@testing-library/user-event": "^13.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "babel-eslint": "^10.1.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "gh-pages": "^6.3.0",
    "globals": "^17.6.0",
    "microbundle-crl": "^0.13.11",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "react": "^16.14.0",
    "react-dom": "^16.14.0",
    "react-scripts": "^5.0.1",
    "semantic-ui-react": "^2.1.5",
    "typescript": "^6.0.3"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "react-infinite-scroll-component": "^6.1.1"
  },
  "types": "dist/index.d.ts",
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/setupTests.js",
      "!src/icons.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 90,
        "lines": 90,
        "statements": 90
      }
    }
  }
}